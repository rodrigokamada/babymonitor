{
  "env": {
    "es2022": true,
    "node": true
  },
  "extends": [
    "airbnb-base"
  ],
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "plugins": [
    "@typescript-eslint"
  ],
  "rules": {
    "class-methods-use-this": "off",
    "import/extensions": [
      "error",
      "ignorePackages",
      {
        "ts": "never"
      }
    ],
    "import/prefer-default-export": "off",
    "lines-between-class-members": "off",
    "max-len": "off",
    "no-empty-function": "off",
    "no-plusplus": "off",
    "no-restricted-syntax": "off",
    "no-useless-constructor": "off",
    "object-curly-newline": "off",
    "padded-blocks": "off"
  },
  "settings": {
    "import/resolver": {
      "node": {
        "extensions": [".js", ".ts"]
      }
    }
  }
}
